---
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} mirlim</span>
	<a href="/subscribe">MCP 서버로 구독</a>
</footer>
<style>
	footer {
		max-width: 720px;
		margin: 0 auto;
		padding: 48px 24px;
		border-top: 1px solid var(--border);
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-size: 0.8rem;
		color: var(--text-muted);
	}
	footer a {
		color: var(--accent);
		text-decoration: none;
	}
	footer a:hover {
		text-decoration: underline;
	}
</style>

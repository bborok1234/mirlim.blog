---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">{SITE_TITLE}</a>
		<div class="links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/subscribe" class="subscribe-link">Subscribe</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		border-bottom: 1px solid var(--border);
	}
	nav {
		max-width: 720px;
		margin: 0 auto;
		padding: 20px 24px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.logo {
		font-family: var(--font-display);
		font-size: 1.25rem;
		color: var(--text);
		text-decoration: none;
	}
	.links {
		display: flex;
		gap: 24px;
	}
	.links :global(a) {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.875rem;
		font-weight: 500;
		transition: color 0.15s;
		padding: 8px 0;
	}
	.links :global(a:hover),
	.links :global(a.active) {
		color: var(--text);
	}
	.links :global(a.subscribe-link) {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		nav { padding: 16px; }
		.links { gap: 16px; }
		.links :global(a) { font-size: 0.8rem; }
	}
</style>

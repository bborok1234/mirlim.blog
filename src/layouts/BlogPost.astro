---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import SeriesNav from '../components/SeriesNav.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	seriesPosts?: Array<{ slug: string; title: string; order: number }>;
};

const { title, description, pubDate, updatedDate, heroImage, tags = [], slug, series, seriesPosts = [] } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} slug={slug} pubDate={pubDate} updatedDate={updatedDate} tags={tags} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={720} height={360} src={heroImage} alt={title} />
					</div>
				)}
				<div class="prose">
					<div class="article-header">
						{series && seriesPosts.length > 1 && (
							<details class="series-top">
								<summary>
									<span class="series-badge">SERIES</span>
									<span class="series-info">
										<a href={`/blog/series/${encodeURIComponent(series)}`}>{series}</a>
										<span class="series-pos">{seriesPosts.sort((a, b) => a.order - b.order).findIndex(p => p.slug === slug) + 1} / {seriesPosts.length}</span>
									</span>
								</summary>
								<ol class="series-toc">
									{seriesPosts.sort((a, b) => a.order - b.order).map((p) => (
										<li class:list={[{ current: p.slug === slug }]}>
											{p.slug === slug ? <span>{p.title}</span> : <a href={`/blog/${p.slug}/`}>{p.title}</a>}
										</li>
									))}
								</ol>
							</details>
						)}
						<div class="meta">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="updated">
									(updated <FormattedDate date={updatedDate} />)
								</span>
							)}
						</div>
						<h1>{title}</h1>
						{tags.length > 0 && (
							<div class="tags">
								{tags.map((tag: string) => (
									<span class:list={['tag', { agent: ['MCP', 'AX', 'AI'].includes(tag) }]}>{tag}</span>
								))}
							</div>
						)}
					</div>
					<slot />
					{series && seriesPosts.length > 1 && (
						<SeriesNav seriesName={series} posts={seriesPosts} currentSlug={slug!} />
					)}
				</div>
			</article>
		</main>
		<Footer />
		<script>
			import mermaid from 'mermaid';
			mermaid.initialize({
				startOnLoad: true,
				theme: 'dark',
				flowchart: {
					padding: 16,
					nodeSpacing: 30,
					rankSpacing: 40,
					useMaxWidth: true,
					htmlLabels: true,
				},
				themeVariables: {
					background: '#0A0A0B',
					primaryColor: '#1C1C1F',
					primaryTextColor: '#E8E8ED',
					primaryBorderColor: '#3B82F6',
					lineColor: '#6B6B76',
					secondaryColor: '#141416',
					tertiaryColor: '#1C1C1F',
					fontFamily: 'Instrument Sans, sans-serif',
					fontSize: '14px',
					nodeBorder: '#3B82F6',
					clusterBkg: '#141416',
					clusterBorder: '#1E1E22',
					edgeLabelBackground: '#141416',
				},
			});
		</script>
	</body>
</html>

<style>
	.hero-image {
		margin-bottom: 32px;
	}
	.hero-image img {
		width: 100%;
		border-radius: 8px;
	}
	.prose {
		max-width: 720px;
		margin: 0 auto;
	}
	.article-header {
		margin-bottom: 48px;
		padding-bottom: 32px;
		border-bottom: 1px solid var(--border);
	}
	.meta {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 12px;
	}
	.updated {
		font-style: italic;
	}
	h1 {
		font-size: 2.5rem;
		letter-spacing: -0.02em;
		line-height: 1.15;
		margin-bottom: 16px;
	}
	.tags {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
	}
	.tag {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		padding: 2px 8px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--text-muted);
	}
	.tag.agent {
		border-color: rgba(59, 130, 246, 0.3);
		color: var(--accent);
		background: rgba(59, 130, 246, 0.06);
	}
	.series-top {
		margin-bottom: 16px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 8px;
		overflow: hidden;
	}
	.series-top summary {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 10px 16px;
		cursor: pointer;
		list-style: none;
	}
	.series-top summary::-webkit-details-marker { display: none; }
	.series-top summary::after {
		content: '▸';
		font-size: 0.75rem;
		color: var(--text-muted);
		margin-left: auto;
		transition: transform 0.15s;
	}
	.series-top[open] summary::after { transform: rotate(90deg); }
	.series-badge {
		font-family: var(--font-mono);
		font-size: 0.65rem;
		font-weight: 600;
		background: var(--accent);
		color: #fff;
		padding: 2px 6px;
		border-radius: 4px;
		letter-spacing: 0.05em;
		flex-shrink: 0;
	}
	.series-info { display: flex; align-items: center; gap: 8px; }
	.series-info a {
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--text);
		text-decoration: none;
	}
	.series-info a:hover { color: var(--accent); }
	.series-pos {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--text-muted);
	}
	.series-toc {
		list-style: none;
		padding: 0 16px 12px;
		margin: 0;
		border-top: 1px solid var(--border);
		counter-reset: stoc;
	}
	.series-toc li {
		counter-increment: stoc;
		padding: 6px 0;
		font-size: 0.875rem;
		display: flex;
		align-items: baseline;
		gap: 8px;
	}
	.series-toc li::before {
		content: counter(stoc) ".";
		font-family: var(--font-mono);
		font-size: 0.75rem;
		color: var(--text-muted);
		min-width: 18px;
	}
	.series-toc li a { color: var(--text-muted); text-decoration: none; }
	.series-toc li a:hover { color: var(--accent); }
	.series-toc li.current span { color: var(--text); font-weight: 500; }
	@media (max-width: 720px) {
		h1 { font-size: 2rem; }
	}
</style>

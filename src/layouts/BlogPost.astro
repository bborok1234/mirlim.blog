---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string };

const { title, description, pubDate, updatedDate, heroImage, tags = [], slug } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} slug={slug} pubDate={pubDate} updatedDate={updatedDate} tags={tags} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				{heroImage && (
					<div class="hero-image">
						<Image width={720} height={360} src={heroImage} alt={title} />
					</div>
				)}
				<div class="prose">
					<div class="article-header">
						<div class="meta">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="updated">
									(updated <FormattedDate date={updatedDate} />)
								</span>
							)}
						</div>
						<h1>{title}</h1>
						{tags.length > 0 && (
							<div class="tags">
								{tags.map((tag: string) => (
									<span class:list={['tag', { agent: ['MCP', 'AX', 'AI'].includes(tag) }]}>{tag}</span>
								))}
							</div>
						)}
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			import mermaid from 'mermaid';
			mermaid.initialize({
				startOnLoad: true,
				theme: 'dark',
				flowchart: {
					padding: 16,
					nodeSpacing: 30,
					rankSpacing: 40,
					useMaxWidth: true,
					htmlLabels: true,
				},
				themeVariables: {
					background: '#0A0A0B',
					primaryColor: '#1C1C1F',
					primaryTextColor: '#E8E8ED',
					primaryBorderColor: '#3B82F6',
					lineColor: '#6B6B76',
					secondaryColor: '#141416',
					tertiaryColor: '#1C1C1F',
					fontFamily: 'Instrument Sans, sans-serif',
					fontSize: '14px',
					nodeBorder: '#3B82F6',
					clusterBkg: '#141416',
					clusterBorder: '#1E1E22',
					edgeLabelBackground: '#141416',
				},
			});
		</script>
	</body>
</html>

<style>
	.hero-image {
		margin-bottom: 32px;
	}
	.hero-image img {
		width: 100%;
		border-radius: 8px;
	}
	.prose {
		max-width: 720px;
		margin: 0 auto;
	}
	.article-header {
		margin-bottom: 48px;
		padding-bottom: 32px;
		border-bottom: 1px solid var(--border);
	}
	.meta {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 12px;
	}
	.updated {
		font-style: italic;
	}
	h1 {
		font-size: 2.5rem;
		letter-spacing: -0.02em;
		line-height: 1.15;
		margin-bottom: 16px;
	}
	.tags {
		display: flex;
		gap: 6px;
		flex-wrap: wrap;
	}
	.tag {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		padding: 2px 8px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--text-muted);
	}
	.tag.agent {
		border-color: rgba(59, 130, 246, 0.3);
		color: var(--accent);
		background: rgba(59, 130, 246, 0.06);
	}
	@media (max-width: 720px) {
		h1 { font-size: 2rem; }
	}
</style>

---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { findRelatedPostsBySlug } from '../../mcp/recommend.js';
import { getGraph, getPost as getMcpPost } from '../../mcp/content.js';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

const graph = getGraph();
const relatedSlugs = findRelatedPostsBySlug(post.id, graph, 3);
const relatedPosts = relatedSlugs
	.map(slug => getMcpPost(slug))
	.filter(Boolean)
	.map(p => ({ slug: p!.slug, title: p!.title, description: p!.description, tags: p!.tags }));

// Series data
let seriesPosts: Array<{ slug: string; title: string; order: number }> = [];
if (post.data.series) {
	const allPosts = await getCollection('blog');
	seriesPosts = allPosts
		.filter(p => !p.data.draft && p.data.series === post.data.series)
		.map(p => ({ slug: p.id, title: p.data.title, order: p.data.seriesOrder ?? 0 }));
}
---

<BlogPost {...post.data} slug={post.id} seriesPosts={seriesPosts}>
	<Content />
	<RelatedPosts posts={relatedPosts} />
</BlogPost>

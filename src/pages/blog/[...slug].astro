---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { findRelatedPostsBySlug } from '../../mcp/recommend.js';
import { getGraph, getPost as getMcpPost } from '../../mcp/content.js';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

const graph = getGraph();
const relatedSlugs = findRelatedPostsBySlug(post.id, graph, 3);
const relatedPosts = relatedSlugs
	.map(slug => getMcpPost(slug))
	.filter(Boolean)
	.map(p => ({ slug: p!.slug, title: p!.title, description: p!.description, tags: p!.tags }));
---

<BlogPost {...post.data}>
	<Content />
	<RelatedPosts posts={relatedPosts} />
</BlogPost>

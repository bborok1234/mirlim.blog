---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog'))
	.filter(p => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [featured, ...rest] = posts;


---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Blog</h1>
			<section class="posts">
				{featured && (
					<article class="featured">
						{featured.data.heroImage && (
							<a href={`/blog/${featured.id}/`} class="featured-img">
								<Image src={featured.data.heroImage} alt="" width={720} height={405} loading="eager" />
							</a>
						)}
						<h2 class="featured-title"><a href={`/blog/${featured.id}/`} class="stretched-link">{featured.data.title}</a></h2>
						<div class="post-meta">
							<FormattedDate date={featured.data.pubDate} />
							{featured.data.series && (
								<a href={`/blog/series/${encodeURIComponent(featured.data.series)}`} class="series-link">
									<span class="series-badge">SERIES</span>{featured.data.series}
								</a>
							)}
							{featured.data.tags.length > 0 && (
								<div class="post-tags">
									{featured.data.tags.map(tag => (
										<a href={`/blog/tag/${encodeURIComponent(tag)}`} class:list={['tag', { agent: ['MCP', 'AX', 'AI'].includes(tag) }]}>{tag}</a>
									))}
								</div>
							)}
						</div>
						<p class="post-desc">{featured.data.description}</p>
					</article>
				)}

				{rest.map((post) => (
					<article class="post">
						<h2 class="post-title"><a href={`/blog/${post.id}/`} class="stretched-link">{post.data.title}</a></h2>
						<div class="post-meta">
							<FormattedDate date={post.data.pubDate} />
							{post.data.series && (
								<a href={`/blog/series/${encodeURIComponent(post.data.series)}`} class="series-link">
									<span class="series-badge">SERIES</span>{post.data.series}
								</a>
							)}
							{post.data.tags.length > 0 && (
								<div class="post-tags">
									{post.data.tags.map(tag => (
										<a href={`/blog/tag/${encodeURIComponent(tag)}`} class:list={['tag', { agent: ['MCP', 'AX', 'AI'].includes(tag) }]}>{tag}</a>
									))}
								</div>
							)}
						</div>
						<p class="post-desc">{post.data.description}</p>
					</article>
				))}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		font-size: 2.5rem;
		margin-bottom: 48px;
	}

	/* Featured */
	.featured {
		position: relative;
		margin-bottom: 32px;
		padding-bottom: 24px;
		border-bottom: 1px solid var(--border);
	}
	.featured-img {
		display: block;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--surface);
		border-radius: 8px;
		margin-bottom: 16px;
	}
	.featured-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 8px;
	}
	.featured-title {
		font-size: 2rem;
		margin-bottom: 8px;
		line-height: 1.2;
	}
	.featured-title a { color: var(--text); text-decoration: none; }
	.featured-title a:hover { color: var(--accent); }
	.featured .post-desc { margin-bottom: 0; }

	.post-meta { position: relative; z-index: 1; }
	.featured-img { position: relative; z-index: 1; }

	/* Post list */
	.post {
		position: relative;
		padding: 24px 0;
		border-bottom: 1px solid var(--border);
	}
	.post:first-of-type { padding-top: 0; }
	.post-title {
		font-size: 1.5rem;
		margin-bottom: 8px;
	}
	.post-title a {
		color: var(--text);
		text-decoration: none;
	}
	.post-title a:hover { color: var(--accent); }
	.post-meta {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 8px;
		display: flex;
		align-items: center;
		gap: 8px 12px;
		flex-wrap: wrap;
	}
	.post-tags { display: flex; gap: 6px; flex-wrap: wrap; }
	.tag {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		padding: 2px 8px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--text-muted);
	}
	a.tag { text-decoration: none; }
	a.tag:hover {
		border-color: var(--text-muted);
		color: var(--text);
	}
	.tag.agent {
		border-color: rgba(59, 130, 246, 0.3);
		color: var(--accent);
		background: rgba(59, 130, 246, 0.06);
	}
	a.tag.agent:hover {
		border-color: var(--accent);
	}
	.series-link {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-size: 0.75rem;
		color: var(--text-muted);
		text-decoration: none;
	}
	.series-link:hover { color: var(--accent); }
	.series-badge {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		font-weight: 600;
		background: var(--accent);
		color: #fff;
		padding: 1px 4px;
		border-radius: 3px;
		letter-spacing: 0.05em;
	}
	.post-desc {
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}
	@media (max-width: 720px) {
		.featured-title { font-size: 1.5rem; }
		.post-title { font-size: 1.25rem; }
		.post .post-tags { display: none; }
	}
</style>

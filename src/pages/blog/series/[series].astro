---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter(p => !p.data.draft);
	const seriesNames = [...new Set(posts.map(p => p.data.series).filter(Boolean))] as string[];
	return seriesNames.map(series => ({
		params: { series },
		props: {
			posts: posts
				.filter(p => p.data.series === series)
				.sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0)),
			series,
		},
	}));
}

const { posts, series } = Astro.props;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`${series} — ${SITE_TITLE}`} description={`시리즈: ${series}`} />
	</head>
	<body>
		<Header />
		<main>
			<div class="series-header">
				<span class="series-badge">SERIES</span>
				<h1>{series}</h1>
				<p class="count">{posts.length}편의 연재</p>
			</div>
			<ol class="posts">
				{posts.map((post: any, idx: number) => (
					<li class="post">
						<span class="order">{idx + 1}</span>
						<div>
							<h2 class="post-title"><a href={`/blog/${post.id}/`} class="stretched-link">{post.data.title}</a></h2>
							<div class="post-meta">
								<FormattedDate date={post.data.pubDate} />
								{post.data.tags.length > 0 && (
									<div class="post-tags">
										{post.data.tags.map((tag: string) => (
											<a href={`/blog/tag/${encodeURIComponent(tag)}`} class:list={['tag', { agent: ['MCP', 'AX', 'AI'].includes(tag) }]}>{tag}</a>
										))}
									</div>
								)}
							</div>
							<p class="post-desc">{post.data.description}</p>
						</div>
					</li>
				))}
			</ol>
		</main>
		<Footer />
	</body>
</html>

<style>
	.series-header { margin-bottom: 32px; }
	.series-badge {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 600;
		background: var(--accent);
		color: #fff;
		padding: 2px 8px;
		border-radius: 4px;
		letter-spacing: 0.05em;
	}
	h1 {
		font-size: 2.5rem;
		margin-top: 12px;
		margin-bottom: 8px;
	}
	.count { color: var(--text-muted); font-size: 0.875rem; }
	.posts {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post {
		position: relative;
		display: flex;
		gap: 16px;
		padding: 24px 0;
		border-bottom: 1px solid var(--border);
	}
	.post:first-of-type { padding-top: 0; }
	.order {
		font-family: var(--font-mono);
		font-size: 1.5rem;
		font-weight: 600;
		color: var(--text-muted);
		min-width: 32px;
		line-height: 1.2;
	}
	.post-meta { position: relative; z-index: 1; }
	.post-title { font-size: 1.75rem; margin-bottom: 8px; }
	.post-title a { color: var(--text); text-decoration: none; }
	.post-title a:hover { color: var(--accent); }
	.post-meta {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 8px;
		display: flex;
		align-items: center;
		gap: 12px;
	}
	.post-tags { display: flex; gap: 6px; }
	.tag {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		padding: 2px 8px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--text-muted);
	}
	a.tag { text-decoration: none; }
	a.tag:hover { border-color: var(--text-muted); color: var(--text); }
	.tag.agent {
		border-color: rgba(59, 130, 246, 0.3);
		color: var(--accent);
		background: rgba(59, 130, 246, 0.06);
	}
	a.tag.agent:hover { border-color: var(--accent); }
	.post-desc { color: var(--text-muted); font-size: 0.95rem; line-height: 1.6; }
	@media (max-width: 720px) {
		.post-title { font-size: 1.25rem; }
		.post-tags { display: none; }
		.order { font-size: 1.25rem; min-width: 24px; }
	}
</style>

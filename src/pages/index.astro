---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.filter(p => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const [featured, ...rest] = posts;
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>AI/AX 시대의<br>생각을 기록합니다</h1>
				<p class="tagline">{SITE_DESCRIPTION}</p>
				<div class="mcp-banner">
					<span class="mcp-badge">MCP</span>
					<span>이 블로그는 AI 에이전트도 읽을 수 있습니다.</span>
					<a href="/subscribe">에이전트에 구독 추가 &rarr;</a>
				</div>
			</section>

			<section class="posts">
				<h2 class="section-label">최근 글</h2>

				{featured && (
					<article class="featured">
						{featured.data.heroImage && (
							<a href={`/blog/${featured.id}/`} class="featured-img">
								<Image src={featured.data.heroImage} alt="" width={720} height={405} loading="eager" />
							</a>
						)}
						<h3 class="featured-title"><a href={`/blog/${featured.id}/`} class="stretched-link">{featured.data.title}</a></h3>
						<div class="post-meta">
							<FormattedDate date={featured.data.pubDate} />
							{featured.data.series && (
								<a href={`/blog/series/${encodeURIComponent(featured.data.series)}`} class="series-link">
									<span class="series-badge">SERIES</span>{featured.data.series}
								</a>
							)}
							{featured.data.tags.length > 0 && (
								<div class="post-tags">
									{featured.data.tags.map(tag => (
										<a href={`/blog/tag/${encodeURIComponent(tag)}`} class:list={['tag', { agent: ['MCP', 'AX', 'AI'].includes(tag) }]}>{tag}</a>
									))}
								</div>
							)}
						</div>
						<p class="post-desc">{featured.data.description}</p>
					</article>
				)}

				{rest.map((post) => (
					<article class="post">
						<h3 class="post-title"><a href={`/blog/${post.id}/`} class="stretched-link">{post.data.title}</a></h3>
						<div class="post-meta">
							<FormattedDate date={post.data.pubDate} />
							{post.data.series && (
								<a href={`/blog/series/${encodeURIComponent(post.data.series)}`} class="series-link">
									<span class="series-badge">SERIES</span>{post.data.series}
								</a>
							)}
							{post.data.tags.length > 0 && (
								<div class="post-tags">
									{post.data.tags.map(tag => (
										<a href={`/blog/tag/${encodeURIComponent(tag)}`} class:list={['tag', { agent: ['MCP', 'AX', 'AI'].includes(tag) }]}>{tag}</a>
									))}
								</div>
							)}
						</div>
						<p class="post-desc">{post.data.description}</p>
					</article>
				))}
				<a href="/blog" class="all-posts">모든 글 보기 &rarr;</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 64px 0 48px;
		border-bottom: 1px solid var(--border);
	}
	.hero h1 {
		font-size: 3.5rem;
		letter-spacing: -0.02em;
		line-height: 1.1;
		margin-bottom: 16px;
	}
	.tagline {
		color: var(--text-muted);
		font-size: 1.125rem;
		max-width: 540px;
		margin-bottom: 32px;
	}
	.mcp-banner {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		padding: 8px 16px;
		background: rgba(59, 130, 246, 0.08);
		border: 1px solid rgba(59, 130, 246, 0.2);
		border-radius: 8px;
		font-size: 0.875rem;
		flex-wrap: wrap;
	}
	.mcp-badge {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 500;
		background: var(--accent);
		color: #fff;
		padding: 2px 8px;
		border-radius: 4px;
		letter-spacing: 0.05em;
	}
	.mcp-banner a {
		color: var(--accent);
		font-weight: 500;
	}
	.posts { padding: 48px 0; }
	.section-label {
		font-family: var(--font-body);
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
		margin-bottom: 32px;
	}

	/* Featured */
	.featured {
		position: relative;
		margin-bottom: 32px;
		padding-bottom: 24px;
		border-bottom: 1px solid var(--border);
	}
	.featured-img {
		display: block;
		aspect-ratio: 16 / 9;
		overflow: hidden;
		background: var(--surface);
		border-radius: 8px;
		margin-bottom: 16px;
	}
	.featured-img img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 8px;
	}
	.featured-title {
		font-size: 2rem;
		margin-bottom: 8px;
		line-height: 1.2;
	}
	.featured-title a {
		color: var(--text);
		text-decoration: none;
	}
	.featured-title a:hover {
		color: var(--accent);
	}
	.featured .post-desc {
		margin-bottom: 0;
	}

	/* Interactive elements sit above the stretched link */
	.post-meta { position: relative; z-index: 1; }
	.featured-img { position: relative; z-index: 1; }

	/* Post list */
	.post {
		position: relative;
		padding: 24px 0;
		border-bottom: 1px solid var(--border);
	}
	.post:first-of-type { padding-top: 0; }
	.post-title {
		font-size: 1.5rem;
		margin-bottom: 8px;
	}
	.post-title a {
		color: var(--text);
		text-decoration: none;
	}
	.post-title a:hover { color: var(--accent); }
	.post-meta {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 8px;
		display: flex;
		align-items: center;
		gap: 8px 12px;
		flex-wrap: wrap;
	}
	.post-tags { display: flex; gap: 6px; flex-wrap: wrap; }
	.tag {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		padding: 2px 8px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--text-muted);
	}
	a.tag { text-decoration: none; }
	a.tag:hover {
		border-color: var(--text-muted);
		color: var(--text);
	}
	.tag.agent {
		border-color: rgba(59, 130, 246, 0.3);
		color: var(--accent);
		background: rgba(59, 130, 246, 0.06);
	}
	a.tag.agent:hover {
		border-color: var(--accent);
	}
	.post-desc {
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}
	.series-link {
		display: inline-flex;
		align-items: center;
		gap: 4px;
		font-size: 0.75rem;
		color: var(--text-muted);
		text-decoration: none;
	}
	.series-link:hover { color: var(--accent); }
	.series-badge {
		font-family: var(--font-mono);
		font-size: 0.6rem;
		font-weight: 600;
		background: var(--accent);
		color: #fff;
		padding: 1px 4px;
		border-radius: 3px;
		letter-spacing: 0.05em;
	}
	.all-posts {
		display: inline-block;
		margin-top: 24px;
		color: var(--accent);
		font-size: 0.875rem;
		font-weight: 500;
	}
	@media (max-width: 720px) {
		.hero h1 { font-size: 2.5rem; }
		.featured-title { font-size: 1.5rem; }
		.post-title { font-size: 1.25rem; }
		.post .post-tags { display: none; }
	}
</style>

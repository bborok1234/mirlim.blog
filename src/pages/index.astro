---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.filter(p => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>AI/AX 시대의<br>생각을 기록합니다</h1>
				<p class="tagline">{SITE_DESCRIPTION}</p>
				<div class="mcp-banner">
					<span class="mcp-badge">MCP</span>
					<span>이 블로그는 AI 에이전트도 읽을 수 있습니다.</span>
					<a href="/subscribe">에이전트에 구독 추가 &rarr;</a>
				</div>
			</section>

			<section class="posts">
				<h2 class="section-label">최근 글</h2>
				{posts.map((post) => (
					<article class="post">
						<h3 class="post-title"><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
						<div class="post-meta">
							<FormattedDate date={post.data.pubDate} />
							{post.data.tags.length > 0 && (
								<div class="post-tags">
									{post.data.tags.map(tag => (
										<span class:list={['tag', { agent: ['MCP', 'AX', 'AI'].includes(tag) }]}>{tag}</span>
									))}
								</div>
							)}
						</div>
						<p class="post-desc">{post.data.description}</p>
					</article>
				))}
				<a href="/blog" class="all-posts">모든 글 보기 &rarr;</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 64px 0 48px;
		border-bottom: 1px solid var(--border);
	}
	.hero h1 {
		font-size: 3.5rem;
		letter-spacing: -0.02em;
		line-height: 1.1;
		margin-bottom: 16px;
	}
	.tagline {
		color: var(--text-muted);
		font-size: 1.125rem;
		max-width: 540px;
		margin-bottom: 32px;
	}
	.mcp-banner {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		padding: 10px 16px;
		background: rgba(59, 130, 246, 0.08);
		border: 1px solid rgba(59, 130, 246, 0.2);
		border-radius: 8px;
		font-size: 0.875rem;
		flex-wrap: wrap;
	}
	.mcp-badge {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		font-weight: 500;
		background: var(--accent);
		color: #fff;
		padding: 2px 8px;
		border-radius: 4px;
		letter-spacing: 0.05em;
	}
	.mcp-banner a {
		color: var(--accent);
		font-weight: 500;
	}
	.posts { padding: 48px 0; }
	.section-label {
		font-family: var(--font-body);
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
		margin-bottom: 32px;
	}
	.post {
		padding: 24px 0;
		border-bottom: 1px solid var(--border);
	}
	.post:first-of-type { padding-top: 0; }
	.post-title {
		font-size: 1.75rem;
		margin-bottom: 8px;
	}
	.post-title a {
		color: var(--text);
		text-decoration: none;
	}
	.post-title a:hover { color: var(--accent); }
	.post-meta {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 8px;
		display: flex;
		align-items: center;
		gap: 12px;
	}
	.post-tags { display: flex; gap: 6px; }
	.tag {
		font-family: var(--font-mono);
		font-size: 0.7rem;
		padding: 2px 8px;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 4px;
		color: var(--text-muted);
	}
	.tag.agent {
		border-color: rgba(59, 130, 246, 0.3);
		color: var(--accent);
		background: rgba(59, 130, 246, 0.06);
	}
	.post-desc {
		color: var(--text-muted);
		font-size: 0.95rem;
		line-height: 1.6;
	}
	.all-posts {
		display: inline-block;
		margin-top: 24px;
		color: var(--accent);
		font-size: 0.875rem;
		font-weight: 500;
	}
	@media (max-width: 720px) {
		.hero h1 { font-size: 2.5rem; }
		.post-title { font-size: 1.375rem; }
	}
</style>

---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Subscribe — ${SITE_TITLE}`} description="AI 에이전트에서 mirlim.blog를 구독하세요. MCP 서버 설치 가이드." />
	</head>
	<body>
		<Header />
		<main>
			<h1>에이전트에 구독 추가하기</h1>
			<p class="intro">
				MCP 서버를 에이전트 하네스에 추가하면,
				AI 에이전트가 직접 블로그 콘텐츠를 읽고 검색하고 질문할 수 있습니다.
			</p>

			<section class="install-guide">
				<h2>Claude Desktop</h2>
				<p class="path"><code>~/Library/Application Support/Claude/claude_desktop_config.json</code></p>
				<div class="code-block">
					<pre><code id="claude-config" set:html={`{\n  <span class="json-key">"mcpServers"</span>: {\n    <span class="json-key">"mirlim-blog"</span>: {\n      <span class="json-key">"url"</span>: <span class="json-str">"https://mirlim.blog/mcp"</span>\n    }\n  }\n}`} /></pre>
					<button class="copy-btn" data-target="claude-config">복사</button>
				</div>

				<h2>Cursor</h2>
				<p class="path"><code>.cursor/mcp.json</code></p>
				<div class="code-block">
					<pre><code id="cursor-config" set:html={`{\n  <span class="json-key">"mcpServers"</span>: {\n    <span class="json-key">"mirlim-blog"</span>: {\n      <span class="json-key">"url"</span>: <span class="json-str">"https://mirlim.blog/mcp"</span>\n    }\n  }\n}`} /></pre>
					<button class="copy-btn" data-target="cursor-config">복사</button>
				</div>

				<h2>Claude Code</h2>
				<p class="path"><code>~/.claude.json</code>의 <code>mcpServers</code></p>
				<div class="code-block">
					<pre><code id="cc-config" set:html={`{\n  <span class="json-key">"mirlim-blog"</span>: {\n    <span class="json-key">"url"</span>: <span class="json-str">"https://mirlim.blog/mcp"</span>\n  }\n}`} /></pre>
					<button class="copy-btn" data-target="cc-config">복사</button>
				</div>
			</section>

			<section class="tools">
				<h2 class="section-label">사용 가능한 도구</h2>
				<div class="tool-row">
					<span class="tool-name">list_posts</span>
					<span class="tool-desc">전체 글 목록 조회 (태그, 날짜, 요약)</span>
				</div>
				<div class="tool-row">
					<span class="tool-name">get_post</span>
					<span class="tool-desc">특정 글 상세 조회 (구조화된 JSON)</span>
				</div>
				<div class="tool-row">
					<span class="tool-name">search_posts</span>
					<span class="tool-desc">키워드/태그 기반 검색</span>
				</div>
				<div class="tool-row">
					<span class="tool-name">ask_blog</span>
					<span class="tool-desc">블로그 콘텐츠에 대한 자연어 질문</span>
				</div>
				<div class="tool-row">
					<span class="tool-name">suggest_topic</span>
					<span class="tool-desc">작성자에게 토픽 제안</span>
				</div>
			</section>

			<section class="discovery">
				<h2 class="section-label">자동 디스커버리</h2>
				<p>
					MCP 디스커버리를 지원하는 클라이언트는
					<a href="/.well-known/mcp.json"><code>/.well-known/mcp.json</code></a>을
					통해 자동으로 이 블로그의 MCP 서버를 찾을 수 있습니다.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script>
	document.querySelectorAll('.copy-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const target = btn.getAttribute('data-target');
			if (!target) return;
			const code = document.getElementById(target);
			if (!code) return;
			navigator.clipboard.writeText(code.textContent ?? '');
			const original = btn.textContent;
			btn.textContent = '복사됨!';
			setTimeout(() => { btn.textContent = original; }, 2000);
		});
	});
</script>

<style>
	h1 { margin-bottom: 16px; }
	.intro {
		color: var(--text-muted);
		font-size: 1.1rem;
		margin-bottom: 48px;
		max-width: 540px;
	}
	.install-guide h2 {
		font-family: var(--font-body);
		font-size: 1.125rem;
		font-weight: 600;
		margin-top: 32px;
		margin-bottom: 8px;
	}
	.path {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-bottom: 8px;
	}
	.code-block {
		position: relative;
		background: var(--surface);
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 20px;
		margin-bottom: 24px;
	}
	.code-block pre {
		margin: 0;
		overflow-x: auto;
	}
	.code-block code {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		line-height: 1.6;
		color: var(--text-muted);
		background: none;
		border: none;
		padding: 0;
	}
	.copy-btn {
		position: absolute;
		top: 12px;
		right: 12px;
		background: var(--surface-hover);
		border: 1px solid var(--border);
		color: var(--text-muted);
		padding: 4px 12px;
		border-radius: 4px;
		font-family: var(--font-mono);
		font-size: 0.7rem;
		cursor: pointer;
		transition: color 0.15s;
	}
	.copy-btn:hover { color: var(--text); }
	.json-key { color: var(--accent); }
	.json-str { color: var(--success); }
	.section-label {
		font-family: var(--font-body);
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--text-muted);
		margin-bottom: 16px;
		margin-top: 48px;
	}
	.tool-row {
		display: flex;
		align-items: baseline;
		gap: 16px;
		padding: 10px 0;
		border-bottom: 1px solid var(--border);
	}
	.tool-name {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--accent);
		min-width: 140px;
	}
	.tool-desc {
		font-size: 0.85rem;
		color: var(--text-muted);
	}
	.discovery {
		margin-top: 48px;
		padding: 24px;
		background: rgba(59, 130, 246, 0.06);
		border: 1px solid rgba(59, 130, 246, 0.15);
		border-radius: 8px;
	}
	.discovery .section-label { margin-top: 0; }
	.discovery p {
		color: var(--text-muted);
		font-size: 0.9rem;
	}
</style>

---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={`Subscribe — ${SITE_TITLE}`} description="AI 에이전트에서 mirlim.blog를 구독하세요. MCP 서버 설치 가이드." />
	</head>
	<body>
		<Header />
		<main>
			<h1>AI 에이전트에 구독 추가하기</h1>
			<p class="intro">
				mirlim.blog의 MCP 서버를 에이전트 하네스에 추가하면,
				AI 에이전트가 직접 블로그 콘텐츠를 읽고, 검색하고, 질문할 수 있습니다.
			</p>

			<section class="install-guide">
				<h2>Claude Desktop</h2>
				<p><code>~/Library/Application Support/Claude/claude_desktop_config.json</code>에 추가:</p>
				<div class="code-block">
					<pre><code id="claude-config">{JSON.stringify({
  mcpServers: {
    "mirlim-blog": {
      url: "https://mirlim.blog/mcp"
    }
  }
}, null, 2)}</code></pre>
					<button class="copy-btn" data-target="claude-config">복사</button>
				</div>

				<h2>Cursor</h2>
				<p><code>.cursor/mcp.json</code>에 추가:</p>
				<div class="code-block">
					<pre><code id="cursor-config">{JSON.stringify({
  mcpServers: {
    "mirlim-blog": {
      url: "https://mirlim.blog/mcp"
    }
  }
}, null, 2)}</code></pre>
					<button class="copy-btn" data-target="cursor-config">복사</button>
				</div>

				<h2>Claude Code</h2>
				<p><code>~/.claude.json</code>의 <code>mcpServers</code>에 추가:</p>
				<div class="code-block">
					<pre><code id="claudecode-config">{JSON.stringify({
  "mirlim-blog": {
    url: "https://mirlim.blog/mcp"
  }
}, null, 2)}</code></pre>
					<button class="copy-btn" data-target="claudecode-config">복사</button>
				</div>
			</section>

			<section class="tools">
				<h2>사용 가능한 도구</h2>
				<table>
					<thead>
						<tr><th>도구</th><th>설명</th></tr>
					</thead>
					<tbody>
						<tr><td><code>list_posts</code></td><td>전체 글 목록 조회 (태그, 날짜, 요약 포함)</td></tr>
						<tr><td><code>get_post</code></td><td>특정 글 상세 조회 (구조화된 JSON)</td></tr>
						<tr><td><code>search_posts</code></td><td>키워드/태그 기반 검색</td></tr>
						<tr><td><code>ask_blog</code></td><td>블로그 콘텐츠에 대한 자연어 질문</td></tr>
						<tr><td><code>suggest_topic</code></td><td>작성자에게 토픽 제안</td></tr>
					</tbody>
				</table>
			</section>

			<section class="discovery">
				<h2>자동 디스커버리</h2>
				<p>
					MCP 디스커버리를 지원하는 클라이언트는
					<code><a href="/.well-known/mcp.json">/.well-known/mcp.json</a></code>을
					통해 자동으로 이 블로그의 MCP 서버를 찾을 수 있습니다.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<script>
	document.querySelectorAll('.copy-btn').forEach(btn => {
		btn.addEventListener('click', () => {
			const target = btn.getAttribute('data-target');
			if (!target) return;
			const code = document.getElementById(target);
			if (!code) return;
			navigator.clipboard.writeText(code.textContent ?? '');
			const original = btn.textContent;
			btn.textContent = '복사됨!';
			setTimeout(() => { btn.textContent = original; }, 2000);
		});
	});
</script>

<style>
	main {
		width: 960px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 2em 0;
	}
	h1 {
		margin-bottom: 0.5em;
	}
	.intro {
		font-size: 1.1em;
		color: rgb(var(--gray-dark));
		margin-bottom: 2em;
	}
	.install-guide h2 {
		margin-top: 2em;
		margin-bottom: 0.5em;
	}
	.code-block {
		position: relative;
		background: rgb(var(--gray-light));
		border-radius: 8px;
		padding: 1em;
		margin: 0.5em 0 1.5em;
	}
	.code-block pre {
		margin: 0;
		overflow-x: auto;
	}
	.copy-btn {
		position: absolute;
		top: 0.5em;
		right: 0.5em;
		background: rgb(var(--accent));
		color: white;
		border: none;
		padding: 0.3em 0.8em;
		border-radius: 4px;
		cursor: pointer;
		font-size: 0.8em;
	}
	.copy-btn:hover {
		opacity: 0.9;
	}
	table {
		width: 100%;
		border-collapse: collapse;
		margin-top: 1em;
	}
	th, td {
		text-align: left;
		padding: 0.75em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	th {
		font-weight: 600;
	}
	.discovery {
		margin-top: 2em;
		padding: 1.5em;
		background: rgb(var(--accent-light));
		border-radius: 8px;
	}
	.discovery h2 {
		margin-top: 0;
	}
</style>
